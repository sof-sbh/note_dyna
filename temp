fetch logs, from: toTimestamp("2026-07-23T15:45:00"), to: toTimestamp("2026-07-23T16:15:00")
| filter loglevel == "ERROR"
| filter in(host.name, {"siewbrpl05.ccas.asmeg.org","siewbrpl06.ccas.asmeg.org","siewbrpl07.ccas.asmeg.org"})
| filter contains(content, "access forbidden")
| summarize count(), by: {client_ip: substring(content, indexOf(content, "client: ") + 8, 15)}
| sort `count()` desc
| limit 15
