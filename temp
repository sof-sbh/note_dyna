fetch dt.davis.problems
| filter not(dt.davis.is_duplicate)
| filter event.status == "ACTIVE"
| expand entity_id = affected_entity_ids
| filter startsWith(toString(entity_id), "HOST-")
| fields
    `Début` = event.start,
    `ID` = display_id,
    `Problème` = event.name,
    `Impact` = dt.davis.impact_level,
    `Host ID` = entity_id
| sort `Début` 

fetch dt.entity.host
| fieldsAdd host_group_id = belongs_to[dt.entity.host_group]
| expand host_group_id
| fieldsAdd host_group = entityName(host_group_id)
| summarize hosts = count(), by:{host_group}
| sort hosts desc




